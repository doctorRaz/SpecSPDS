<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net6.0-windows</TargetFramework>
		<ImplicitUsings>disable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<UseWindowsForms>true</UseWindowsForms>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		<RootNamespace>dRz.SpecSPDS.Cad</RootNamespace>
		<PlatformTarget>x64</PlatformTarget>
		<BaseOutputPath>..\bin.NET</BaseOutputPath>

	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
		<DefineConstants>$(DefineConstants);NC</DefineConstants>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
		<DefineConstants>$(DefineConstants);NC</DefineConstants>
	</PropertyGroup>

	<ItemGroup>
		<Compile Include="..\SpecSPDS.Core\InternalDiagnostic\DebugTextWriter.cs" Link="InternalDiagnostic\DebugTextWriter.cs" />
		<Compile Include="..\SpecSPDS.Core\InternalDiagnostic\InternalLoggerDiagnostic.cs" Link="InternalDiagnostic\InternalLoggerDiagnostic.cs" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SpecSPDS.Core\SpecSPDS.Core.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="MultiCAD.NET" Version="23.0.6177.4117" />
		<PackageReference Include="nanoCAD.Platform.NET" Version="23.0.6177.4117" />
		<PackageReference Include="NLog" Version="6.0.7"/>
	</ItemGroup>


