<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net6.0-windows</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<UseWindowsForms>true</UseWindowsForms>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		<RootNamespace>dRz.SpecSPDS.Cad</RootNamespace>
		<PlatformTarget>x64</PlatformTarget>
		<BaseOutputPath>..\bin.NET</BaseOutputPath>

	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
		<DefineConstants>$(DefineConstants);NC</DefineConstants>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
		<DefineConstants>$(DefineConstants);NC</DefineConstants>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\SpecSPDS.Core\SpecSPDS.Core.csproj" />
	</ItemGroup>

<ItemGroup>
  <PackageReference Include="MultiCAD.NET" Version="23.0.6177.4117" />
  <PackageReference Include="NLog" Version="6.0.7" />
	<PackageReference Include="nanoCAD.Platform.NET" Version="25.0.6785.4733" />
</ItemGroup>

</Project>
