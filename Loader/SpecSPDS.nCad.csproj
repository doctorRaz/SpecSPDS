<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net462</TargetFramework>
		<PlatformTarget>x64</PlatformTarget>
		<RootNamespace>dRz.Loader.nCad</RootNamespace>
		<Nullable>enable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>
		<CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
		<!--******-->
		<Description>Загрузчик модулей SpecSPDS под версию CAD</Description>
		<AssemblyTitle>SpecSPDS.Loader</AssemblyTitle>
	</PropertyGroup>
	<PropertyGroup>
		<DefineConstants>$(DefineConstants);NC</DefineConstants>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="_Draft\**" />
		<EmbeddedResource Remove="_Draft\**" />
		<None Remove="_Draft\**" />
	</ItemGroup>
	<ItemGroup>
	  <Compile Include="..\SpecSPDS\AssemblyResolve\AssemblyResolver.cs" Link="AssembLyResolve\AssemblyResolver.cs" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="nanoCAD.Platform.NET" Version="21.0.5699.3427" />
		<PackageReference Include="NLog" Version="6.0.7" />
	</ItemGroup>
</Project>
