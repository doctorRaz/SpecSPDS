<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<!--<TargetFramework>netstandard2.0</TargetFramework>-->
		<TargetFramework>net462</TargetFramework>
		<RootNamespace>dRz.Cad.Diagnostics</RootNamespace>
		<Description>Среда окружения аддона</Description>
		<AssemblyTitle>dRz.Cad.Diagnostics</AssemblyTitle>
		<Product>dRz.Cad.Diagnostics</Product>
		<InformationalVersion>dRz.Cad.Diagnostics for All</InformationalVersion>

	</PropertyGroup>
	<PropertyGroup>
		<DefineConstants>$(DefineConstants);CMD</DefineConstants>
	</PropertyGroup>
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="AddOn\_draft\**" />
		<Compile Remove="Cad\_draft\**" />
		<Compile Remove="Os\_draft\**" />
		<Compile Remove="_draft\**" />
		<EmbeddedResource Remove="AddOn\_draft\**" />
		<EmbeddedResource Remove="Cad\_draft\**" />
		<EmbeddedResource Remove="Os\_draft\**" />
		<EmbeddedResource Remove="_draft\**" />
		<None Remove="AddOn\_draft\**" />
		<None Remove="Cad\_draft\**" />
		<None Remove="Os\_draft\**" />
		<None Remove="_draft\**" />
	</ItemGroup>
	<ItemGroup>
	  <PackageReference Include="System.Runtime.InteropServices.RuntimeInformation" Version="4.3.0" />
	</ItemGroup>

</Project>
