<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      internalLogLevel="off"
      throwExceptions="false"
      throwconfigexceptions="true"
      internalLogFile="logs\internal.log"
      internalLogToConsole="true">
<!-- ************************* -->
<!--https://github.com/NLog/NLog/wiki/CsvLayout-->
<!-- https://github.com/NLog/NLog/wiki/Date-layout-renderer -->
<!--********** Цели ************-->
	<!--Переменные-->
	<!-- уровень сообщений по быстрому		 -->
	<variable name="FinalLevel"
	          value="${var:LevelMay:whenEmpty=Error}"/>
	<!-- путь к фойлу лога		 -->
	<variable name="FinalLogsDir"
	          value="${var:LogsDir:whenEmpty=${nlogdir:dir=logs}}"/>
	<!-- титул приложения		 -->
	<variable name="FinalAppTitle"
	          value="${var:AppTitle:whenEmpty=AppTitle}"/>
	<targets>
		<target xsi:type="AsyncWrapper"
		        name="asyncXmlFileLoader"
		        queueLimit="10000"
		        overflowAction="Discard"
		        batchSize="500"
		        timeToSleepBetweenBatches="1">
			<target name="xmlFileLoader"
			        xsi:type="File"
			        fileName="${var:FinalLogsDir}/${shortdate}_${var:FinalAppTitle}.log"
			        archiveEvery="Day"
			        archiveAboveSize="5242880"
			        archiveNumbering="Rolling"
			        archiveFileName="${var:FinalLogsDir}/${shortdate}_${var:FinalAppTitle}.{#}.log"
			        maxArchiveFiles="10"
			        keepFileOpen="true"
			        OpenFileCacheTimeout="30">
				<layout xsi:type="XmlLayout"
				        includeEventProperties="true"
				        indentXML="true"
				        maxRecursionLimit="10"
				        elementName='logevent'>
					<attribute name="time"
					           layout="${longdate}"/>
					<attribute name="level"
					           layout="${level:upperCase=true}"/>
					<attribute name="logger"
					           layout="${logger}"/>
					<element name="message"
					         value="${message}"/>
					<element name="error"
					         value="${exception:format=ToString}"/>
				</layout>
			</target>
		</target>
	</targets>
	<!--Правила-->
	<rules>
		<logger name="*"
		        minlevel="${var:FinalLevel}"
		        writeTo="asyncXmlFileLoader"/>
	</rules>
</nlog>
