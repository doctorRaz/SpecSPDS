<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      throwExceptions="true"
      autoReload="true">
	<!--Переменные-->
	<!--Дата время пишем из аддона-->
	<variable name="logTimestamp"
	          value="${gdc:item=logTimestamp}"/>
	<!--Имя метода-->
	<variable name="methodName"
	          value="${callsite:className=false:methodName=true:includeSourcePath=false}"/>
	<!--Имя add-on, пишем из адона-->
	<variable name="addonName"
	          value="${gdc:item=addonName}"/>
	<!--Имя приложения верхнего уровня, нана или еще кто, пишем из адона-->
	<variable name="appName"
	          value="${gdc:item=appName}"/>
	<variable name="logFileName"
	          value="${nlogdir:dir=logs}/${logTimestamp}${methodName}_${appName}"/>
	<!--Шаблон-->
	<variable name="fileLayout"
	          value="${longdate}|${uppercase:${level}}|${logger}|${message}
					${onexception:${newline}${exception:format=ToString}}"/>
	<!-- уровень сообщений по быстрому		 -->
	<variable name="LevelMay"
	          value="Trace"/>
	<!--//Переменные-->
	<!-- ************************* -->
	<!--https://github.com/NLog/NLog/wiki/CsvLayout-->
	<!--********** Цели ************-->
	<!--Console-->
	<targets>
		<target name="logconsole"
		        xsi:type="ColoredConsole"/>
	</targets>
	<!--пишем асинхронно-->
	<targets async="true">
	<!-- <targets> -->
		<!--		
		Parser
<logevent time="%d{yyyy-MM-dd %H:mm:ss.ffff}" level="%p">
<message>%m{message}</message>
<error> %S{error}</error>
<prop1> %S{prop1}</prop1>
<prop2> %S{prop2}</prop1>
</logevent>		
		-->
		<!--xml-->
		<target name="xmlFile"
		        xsi:type="File"
		        fileName="${nlogdir:dir=logs}/Loader.xml">
			<layout xsi:type="XmlLayout"
			        includeEventProperties="true"
					indentXML="true"
					maxRecursionLimit="10"
			        elementName='logevent'>
				<attribute name="time"
				           layout="${longdate}"/>
				<attribute name="level"
				           layout="${level:upperCase=true}"/>
				<element name="message"
				         value="${message}"/>
				<element name="error"
				         value="${exception:format=ToString}"/>
				<element name="prop1"
				         layout="${event-properties:prop1}"/>
				<element name="prop2"
				         layout="${event-properties:prop2}"/>
			</layout>
		</target>
		
	</targets>
	<!--Правила-->
	<rules>
		<logger name="*"
		        minlevel="${LevelMay}"
		        writeTo="xmlFile"/>
	</rules>
</nlog>