<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      internalLogLevel="off"
      throwExceptions="false"
      throwconfigexceptions="false"
      internalLogFile="c:\temp\_SpecSPDS\logs\internal.log"
      internalLogToConsole="true">
	<!--Переменные-->
	<!-- уровень сообщений по быстрому		 -->
	<variable name="LevelMay"
	          value="Error"/>
	<!-- путь к фойлу лога		 -->
	<variable name="LogsDir"
	          value="${nlogdir:dir=logs}"/>
	<!-- титул приложения		 -->
	<variable name="AppTitle"
	          value="AppTitle"/>
	<!-- количество архивных файлов -->
	<variable name="maxArchiveFiles"
	          value="10"/>
	<!-- размер архива  1024 ^2 * 5 =5242880 -->
	<variable name="archiveAboveSize"
	          value="5242880"/>
	<!-- Default каталог логов по умолчанию -->
	<!-- <variable name="DefaultLogDir" -->
	<!-- value="${nlogdir:dir=logs}"/> -->
	<!-- Default имя лога по умолчанию -->
	<!-- <variable name="DefaultLogName" -->
	<!-- value="App"/> -->
	<!-- ********GDC****************** -->
	<!-- <variable name="LogsDir" -->
	<!-- value="${gdc:LogsDir:whenEmpty=${DefaultLogDir}}"/> -->
	<!-- <variable name="AppName" -->
	<!-- value="${gdc:AppName:whenEmpty=${DefaultLogName}}"/> -->
	<!-- собираем пути имена -->
	<!-- <variable name="LogDate" -->
	<!-- value="${date:universalTime=true:format=yyyy-MM-dd HH\:mm\:ss.ffff}"/> -->
	<!-- <variable name="LogPath" -->
	<!-- value="${var:LogsDir}/${var:LogDate}_${var:AppName}"/> -->
	<!--//Переменные-->
	<!-- ************************* -->
	<!--https://github.com/NLog/NLog/wiki/CsvLayout-->
	<!-- https://github.com/NLog/NLog/wiki/Date-layout-renderer -->
	<!--********** Цели ************-->
	<!--пишем асинхронно-->
	<!-- async="true" -->
	<targets>
		<target xsi:type="AsyncWrapper"
		        name="asyncXmlFileLoader"
		        queueLimit="10000"
		        overflowAction="Discard"
		        batchSize="300"
		        timeToSleepBetweenBatches="10">
			<target name="xmlFileLoader"
			        xsi:type="File"
			        fileName="${var:LogsDir}/${shortdate}_${var:AppTitle}.log"
			        archiveEvery="Day"
			        archiveAboveSize="${archiveAboveSize}"
			        archiveNumbering="Rolling"
			        archiveFileName="${var:LogsDir}/${shortdate}_${var:AppTitle}.{#}.log"
			        maxArchiveFiles="${maxArchiveFiles}"
			        keepFileOpen="true"
			        OpenFileCacheTimeout="30">
				<layout xsi:type="XmlLayout"
				        includeEventProperties="true"
				        indentXML="true"
				        maxRecursionLimit="10"
				        elementName='logevent'>
					<attribute name="time"
					           layout="${longdate}"/>
					<attribute name="level"
					           layout="${level:upperCase=true}"/>
					<attribute name="logger"
					           layout="${logger}"/>
					<element name="message"
					         value="${message}"/>
					<element name="error"
					         value="${exception:format=ToString}"/>
				</layout>
			</target>
		</target>
	</targets>
	<!--Правила-->
	<rules>
		<logger name="*"
		        minlevel="${var:LevelMay}"
		        writeTo="xmlFileLoader"/>
	</rules>
</nlog>
