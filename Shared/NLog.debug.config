<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      throwExceptions="true"
      autoReload="true">
	<!--Переменные-->
	<!--Дата время пишем из аддона-->
	<variable name="logTimestamp"
	          value="${gdc:item=logTimestamp}"/>
	<!--Имя метода-->
	<variable name="methodName"
	          value="${callsite:className=false:methodName=true:includeSourcePath=false}"/>
	<!--Имя add-on, пишем из адона-->
	<variable name="addonName"
	          value="${gdc:item=addonName}"/>
	<!--Имя приложения верхнего уровня, нана или еще кто, пишем из адона-->
	<variable name="appName"
	          value="${gdc:item=appName}"/>
	<variable name="logFileName"
	          value="${nlogdir:dir=logs}/${logTimestamp}${methodName}_${appName}"/>
	<!--Шаблон-->
	<variable name="fileLayout"
	          value="${longdate}|${uppercase:${level}}|${logger}|${message}
					${onexception:${newline}${exception:format=ToString}}"/>
	<!-- уровень сообщений по быстрому		 -->
	<variable name="LevelMay"
	          value="Trace"/>
	<!--//Переменные-->
	<!-- ************************* -->
	<!--https://github.com/NLog/NLog/wiki/CsvLayout-->
	<!--********** Цели ************-->
	<!--Console-->
	<targets>
		<target name="logconsole"
		        xsi:type="ColoredConsole"/>
	</targets>
	<!--пишем асинхронно-->
	<targets async="true">
	<!-- <targets> -->
		<!--		
		Parser
<logevent time="%d{yyyy-MM-dd %H:mm:ss.ffff}" level="%p">
<message>%m{message}</message>
<error> %S{error}</error>
<prop1> %S{prop1}</prop1>
<prop2> %S{prop2}</prop1>
</logevent>		
		-->
		<!--xml-->
		<target name="xmlFile"
		        xsi:type="File"
		        fileName="${nlogdir:dir=logs}/log.xml">
			<layout xsi:type="XmlLayout"
			        includeEventProperties="true"
					indentXML="true"
					maxRecursionLimit="10"
			        elementName='logevent'>
				<attribute name="time"
				           layout="${longdate}"/>
				<attribute name="level"
				           layout="${level:upperCase=true}"/>
				<element name="message"
				         value="${message}"/>
				<element name="error"
				         value="${exception:format=ToString}"/>
				<element name="prop1"
				         layout="${event-properties:prop1}"/>
				<element name="prop2"
				         layout="${event-properties:prop2}"/>
			</layout>
		</target>
		<!--JSON-->
		<target xsi:type="File"
		        name="jsonFile"
		        fileName="${nlogdir:dir=logs}/${shortdate}_${processname}.json">
			<layout xsi:type="JsonLayout">
				<attribute name="time"
				           layout="${longdate}"/>
				<attribute name="level"
				           layout="${level}"/>
				<attribute name="logger"
				           layout="${logger}"/>
				<attribute name="message"
				           layout="${message}"/>
				<attribute name="properties"
				           encode="false">
					<layout xsi:type="JsonLayout"
					        includeEventProperties="true"
					        maxRecursionLimit="2"/>
				</attribute>
				<attribute name="exception"
				           encode="false">
					<layout xsi:type="JsonLayout">
						<attribute name="type"
						           layout="${exception:format=type}"/>
						<attribute name="message"
						           layout="${exception:format=message}"/>
						<attribute name="stacktrace"
						           layout="${exception:format=tostring}"/>
					</layout>
				</attribute>
			</layout>
		</target>
		<!--CSV-->
		<target xsi:type="File"
		        name="csvFileExample"
		        fileName="${nlogdir:dir=logs}/${shortdate}_${processname}.csv">
			<layout xsi:type="CsvLayout"
			        delimiter="Tab"
			        withHeader="true"
			        quoting="All">
				<column name="time"
				        layout="${longdate}"/>
				<column name="level"
				        layout="${level:upperCase=true}"/>
				<column name="logger"
				        layout="${logger}"/>
				<column name="message"
				        layout="${message}"/>
				<column name="exception"
				        layout="${exception:format=ToString}"/>
				<column name="prop1"
				        layout="${event-properties:prop1}"/>
				<column name="prop2"
				        layout="${event-properties:prop2}"/>
			</layout>
		</target>
		<!--File CSV Test-->
		<target xsi:type="File"
		        name="csvFile"
		        fileName="${nlogdir:dir=logs}/log.csv"
		        layout="${longdate}|${level}|${logger}|${message}|${exception}|${event-properties:prop1}|${event-properties:item=prop2}"/>
		<!--File-->
		<target name="logfile"
		        xsi:type="File"
		        fileName="${logFileName}.log"/>
		<!--File Err-->
		<target name="logfileErr"
		        xsi:type="File"
		        fileName="${logFileName}_Err.log"/>
		<target name="logfileInfo"
		        xsi:type="File"
		        fileName="${nlogdir:dir=logs}/${shortdate}_${processname}.log"/>
	</targets>
	<!--Правила-->
	<rules>
		<logger name="*"
		        minlevel="${LevelMay}"
		        writeTo="xmlFile"/>
		<logger name="*"
		        minlevel="${LevelMay}"
		        writeTo="csvFile"/>
		<logger name="*"
		        minlevel="${LevelMay}"
		        writeTo="logconsole"/>
		<logger name="*"
		        minlevel="${LevelMay}"
		        writeTo="logfile"/>
		<logger name="*"
		        minlevel="Error"
		        writeTo="logfileErr"/>
		<logger name="*"
		        minlevel="${LevelMay}"
		        writeTo="logfileInfo"/>
		<logger name="*"
		        minlevel="${LevelMay}"
		        writeTo="csvFileExample"/>
		<logger name="*"
		        minlevel="${LevelMay}"
		        writeTo="jsonFile"/>
	</rules>
</nlog>