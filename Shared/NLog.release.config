<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      throwExceptions="true"
      autoReload="true">

	<!--Переменные-->

	<!--Дата время пишем из аддона-->
	<variable name="logTimestamp"
	          value="${gdc:item=logTimestamp}"/>

	<!--Имя метода-->
	<variable name="methodName"
	          value="${callsite:className=false:methodName=true:includeSourcePath=false}"/>

	<!--Имя приложения верхнего уровня, нана или еще кто, пишем из адона-->
	<variable name="appName"
	          value="${gdc:item=appName}"/>
	<variable name="logFileName"
	          value="${basedir}/logs/${logTimestamp}${methodName}_${appName}"/>

	<!--шаблон сообщения-->
	<!--<variable name="layoutDef"
	          value="${longdate}|${level:uppercase=true}|${callsite}|${callsite-linenumber}|${message}"/>-->
	<variable name="layoutDef"
	          value="${longdate}|${level:uppercase=true}|${logger}|${message}"/>

	<!--Цели-->
	<targets >
		<target name="logconsole"
		        xsi:type="ColoredConsole"/>
	</targets>
	
	<targets async="true">
		<target name="logfile"
		        xsi:type="File"
		        fileName="${basedir}/logs/${shortdate}_${processname}.log"
		keepFileOpen="true"/>
	</targets>


	<!--Правила-->
	<rules>
		<logger name="*"
		        minlevel="Warn"
		        writeTo="logconsole"/>
		<logger name="*"
		        minlevel="Warn"
		        writeTo="logfile"/>
		<includeSourceInfo>true</includeSourceInfo>
	</rules>
</nlog>