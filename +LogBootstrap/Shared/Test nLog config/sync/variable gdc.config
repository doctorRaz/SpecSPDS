<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      internalLogLevel="off"
      throwExceptions="false"
      throwconfigexceptions="true"
      internalLogFile="c:\temp\_SpecSPDS\logs\internal.log" internalLogToConsole="true">
	<!--Переменные-->
	<!-- уровень сообщений по быстрому		 -->
	<variable name="LevelMay"
			  value="Trace" />
	<!-- количество архивных файлов -->
	<variable name="maxArchiveFiles"
			  value="10" />
	<!--размер архива  1024 ^2 * 5 =5242880 -->
	<variable name="archiveAboveSize"
			  value="5242880" />
	<!-- Default каталог логов по умолчанию -->
	<variable name="DefaultLogDir"
			  value="${nlogdir:dir=logs}" />
	<!-- Default имя лога по умолчанию -->
	<variable name="DefaultLogName"
			  value="App" />
	<!-- ********GDC****************** -->
	<variable name="LogsDir"
			  value="${gdc:LogsDir}" />
	<variable name="AppName"
			  value="${gdc:AppName}" />
	<!-- собираем пути имена -->
	<variable name="LogDate"
			  value="${date:universalTime=true:format=yyyy-MM-dd HH\:mm\:ss}" />
	<variable name="LogPath"
			  value="${var:LogsDir}/${var:LogDate}_${var:AppName}" />
	<!--//Переменные-->
	<!-- ************************* -->
	<!--https://github.com/NLog/NLog/wiki/CsvLayout-->
	<!-- https://github.com/NLog/NLog/wiki/Date-layout-renderer -->
	<!--********** Цели ************-->
	<!--пишем асинхронно-->
	<!-- async="true" -->
	<targets>
		<!--xml для загрузчика-->
		<target name="xmlFileLoader"
				xsi:type="File"
				fileName="${var:LogPath}.Loader.log"
				archiveEvery="Day"
				archiveAboveSize="${archiveAboveSize}"
				archiveNumbering="Rolling"
				archiveFileName="${var:LogPath}.Loader.{#}.log"
				maxArchiveFiles="${maxArchiveFiles}"
				keepFileOpen="false">
			<layout xsi:type="XmlLayout"
					includeEventProperties="true"
					indentXML="true"
					maxRecursionLimit="10"
					elementName='logevent'>
				<attribute name="time"
						   layout="${longdate}" />
				<attribute name="level"
						   layout="${level:upperCase=true}" />
				<attribute name="logger"
						   layout="${logger}" />
				<element name="message"
						 value="${message}" />
				<element name="error"
						 value="${exception:format=ToString}" />
				<element name="prop1"
						 layout="${event-properties:prop1}" />
				<element name="prop2"
						 layout="${event-properties:prop2}" />
			</layout>
		</target>
		<!--xml для адаптера-->
		<target name="xmlFileAdapter"
				xsi:type="File"
				fileName="${var:LogPath}.Adapter.log"
				archiveEvery="Day"
				archiveAboveSize="${archiveAboveSize}"
				archiveNumbering="Rolling"
				archiveFileName="${var:LogPath}.Adapter.{#}.log"
				maxArchiveFiles="${maxArchiveFiles}"
				keepFileOpen="false">
			<layout xsi:type="XmlLayout"
					includeEventProperties="true"
					indentXML="true"
					maxRecursionLimit="10"
					elementName='logevent'>
				<attribute name="time"
						   layout="${longdate}" />
				<attribute name="level"
						   layout="${level:upperCase=true}" />
				<attribute name="logger"
						   layout="${logger}" />
				<element name="message"
						 value="${message}" />
				<element name="error"
						 value="${exception:format=ToString}" />
				<element name="prop1"
						 layout="${event-properties:prop1}" />
				<element name="prop2"
						 layout="${event-properties:prop2}" />
			</layout>
		</target>
	</targets>
	<!--Правила-->
	<rules>
		<logger name="dRz.Loader*" minlevel="${LevelMay}" writeTo="xmlFileLoader" final="true" />
		<logger name="*" minlevel="${LevelMay}" writeTo="xmlFileAdapter" />
	</rules>
</nlog>
<!--help-->
<!--Parser-->
