<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net6.0-windows</TargetFramework>
		<ImplicitUsings>disable</ImplicitUsings>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<UseWPF>true</UseWPF>
		<Nullable>enable</Nullable>
		<Description>Отладка в консоли</Description>
		<RootNamespace>dRz.SpecSpds.Test</RootNamespace>
		<BaseOutputPath>..\bin.NET</BaseOutputPath>
	</PropertyGroup>

	<ItemGroup>
	  <Compile Remove="_draft\**" />
	  <Compile Remove="_experimental\**" />
	  <EmbeddedResource Remove="_draft\**" />
	  <EmbeddedResource Remove="_experimental\**" />
	  <None Remove="_draft\**" />
	  <None Remove="_experimental\**" />
	  <Page Remove="_draft\**" />
	  <Page Remove="_experimental\**" />
	</ItemGroup>

	<ItemGroup>
	  <Compile Include="..\SpecSPDS.NCad\Infrastructure\Bootstrap\LogBootstrap.cs" Link="Infrastructure\Bootstrap\LogBootstrap.cs" />
	  <Compile Include="..\SpecSPDS.NCad\Infrastructure\LoaderEnvironment.cs" Link="Infrastructure\LoaderEnvironment.cs" />
	  <Compile Include="..\SpecSPDS.NCad\Infrastructure\InternalDiagnostic\DebugTextWriter.cs" Link="Infrastructure\InternalDiagnostic\DebugTextWriter.cs" />
	  <Compile Include="..\SpecSPDS.NCad\Infrastructure\InternalDiagnostic\InternalLoggerDiagnostic.cs" Link="Infrastructure\InternalDiagnostic\InternalLoggerDiagnostic.cs" />
	  
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="NLog" Version="6.0.7">
			<!--<PrivateAssets>all</PrivateAssets>-->
		</PackageReference>
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\SpecSPDS.Core\SpecSPDS.Core.csproj" />
	</ItemGroup>


