<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net6.0-windows</TargetFramework>
		<PlatformTarget>x64</PlatformTarget>
		<RootNamespace>dRz.SpecSPDS.nCad</RootNamespace>
		<Nullable>enable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>
		<UseWindowsForms>true</UseWindowsForms>
		<UseWPF>true</UseWPF>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		<!--******************-->
		<Description>Спецификация из универсального маркера, nanoCAD 23-25</Description>
		<AssemblyTitle>SpecSPDS.NET.23</AssemblyTitle>
	</PropertyGroup>
	<PropertyGroup>
		<DefineConstants>$(DefineConstants);NC</DefineConstants>
	</PropertyGroup>
	<ItemGroup>
		<ProjectReference Include="..\Core\SpecSPDS.Core.csproj" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="MultiCAD.NET" Version="23.0.6177.4117" />
		<PackageReference Include="nanoCAD.Platform.NET" Version="23.0.6177.4117" />
		<PackageReference Include="NLog" Version="6.0.7" />
	</ItemGroup>
</Project>
