		<PackageReference Include="MultiCAD.NET" Version="23.1.6324.4405" />
		<PackageReference Include="nanoCAD.Platform.NET" Version="23.1.6324.4405" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\SpecSPDS.Core\SpecSPDS.Core.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="CadCommands\Common\" />
	  <Folder Include="Enums\" />
	</ItemGroup>

</Project>
