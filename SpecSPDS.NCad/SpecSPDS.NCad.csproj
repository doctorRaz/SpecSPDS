<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net6.0</TargetFramework>
		<ImplicitUsings>disable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<RootNamespace>dRz.Loader.Cad</RootNamespace>

		<BaseOutputPath>..\bin.NET\</BaseOutputPath>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>

		<Description>Загрузчик модулей SpecSPDS под версию CAD</Description>

		<!--<GenerateAssemblyFileVersionAttribute>false</GenerateAssemblyFileVersionAttribute>
		<GenerateAssemblyInformationalVersionAttribute>false</GenerateAssemblyInformationalVersionAttribute>-->
		<!--<Deterministic>false</Deterministic>-->
		<!--<AssemblyVersion>1.1.*</AssemblyVersion>-->
		<!--<Product>nCadLoader</Product>-->
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
		<DefineConstants>$(DefineConstants);NC</DefineConstants>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
		<DefineConstants>$(DefineConstants);NC</DefineConstants>
	</PropertyGroup>

	<ItemGroup>
		<Compile Include="..\SpecSPDS.Core\InternalDiagnostic\DebugTextWriter.cs" Link="_InternalDiagnostic\DebugTextWriter.cs" />
		<Compile Include="..\SpecSPDS.Core\InternalDiagnostic\InternalLoggerDiagnostic.cs" Link="_InternalDiagnostic\InternalLoggerDiagnostic.cs" />
		<Compile Include="..\_experimental\LogBootstrap.cs" Link="Bootstrap\LogBootstrap.cs" />
	</ItemGroup>

	<!--<ItemGroup>
	  <Compile Remove="_experimental\**" />
	  <EmbeddedResource Remove="_experimental\**" />
	  <None Remove="_experimental\**" />
	</ItemGroup>-->

	<ItemGroup>
		<PackageReference Include="nanoCAD.Platform.NET" Version="23.0.6177.4117" />
		<PackageReference Include="NLog" Version="6.0.7">
			<!--<PrivateAssets>all</PrivateAssets>-->
		</PackageReference>
	</ItemGroup>

