	<!-- </Target> -->
	
	  <PropertyGroup>
    <!-- Общая папка с конфигурацией -->
    <SharedConfigDir>$(MSBuildThisFileDirectory)Shared</SharedConfigDir>
  </PropertyGroup>

  <Target Name="CopyNLogConfig"
          AfterTargets="Build"
          Inputs="$(SharedConfigDir)\NLog.$(Configuration).config"
          Outputs="$(OutDir)NLog.config"
          Condition="Exists('$(SharedConfigDir)\NLog.$(Configuration).config')">

    <Copy
      SourceFiles="$(SharedConfigDir)\NLog.$(Configuration).config"
      DestinationFiles="$(OutDir)NLog.config"
      SkipUnchangedFiles="true" />

  </Target>

</Project>
