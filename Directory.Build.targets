<Project>
	<PropertyGroup>
	
	<!-- не фурычит	 -->
	<!-- <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath> -->
	
		<!--<DateTime -->
		<StartYear>2014</StartYear>
		<CurrentYear>$([System.DateTime]::Now.Year)</CurrentYear>
				
		<!--<Version />-->
		<Deterministic>false</Deterministic>
		<AssemblyVersion>0.1.*</AssemblyVersion>
		<GenerateAssemblyFileVersionAttribute>false</GenerateAssemblyFileVersionAttribute>
		<GenerateAssemblyInformationalVersionAttribute>false</GenerateAssemblyInformationalVersionAttribute>
		<!--<Version />-->
		
		<!--<Name space />-->
		<RootUser>drz</RootUser>
		<RootNamespace>$(RootUser).$(MSBuildProjectName.Replace(" ", "_"))</RootNamespace>
		
		<!--<Name space />-->	
		<!-- Description -->
		<!-- <Product>SpecSPDS</Product> -->
		<Company>doctorRAZ</Company>
		<Authors>Разыграев Андрей</Authors>
		<!--<Description>Спецификация из универсального маркера в nanoCAD 23 и новее</Description>-->
		<Copyright>Разыграев Андрей</Copyright>
		<Trademark>©doctorRaz $(StartYear)-$(CurrentYear)</Trademark>
		<!-- Description -->
		<!--<BaseOutputPath>..\bin.NET\</BaseOutputPath>-->
	</PropertyGroup>
	<PropertyGroup>
		<SharedConfigDir>$(SolutionDir)\Shared</SharedConfigDir>
	</PropertyGroup>

	<Target Name="CopyNLogConfig" AfterTargets="Build">
		<Copy
		  SourceFiles="$(SharedConfigDir)\NLog.$(Configuration).config"
		  DestinationFiles="$(OutDir)NLog.config"
		  SkipUnchangedFiles="true"
		  Condition="Exists('$(SharedConfigDir)\NLog.$(Configuration).config')" />
	</Target>

</Project>
